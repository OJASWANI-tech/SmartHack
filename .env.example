# .env.example  — copy to .env and fill in real values
DATABASE_URL=postgresql://eventflow:eventflow@db:5432/eventflow
REDIS_URL=redis://redis:6379/0
GROQ_API_KEY=
JWT_SECRET_KEY=your-random-secret-here
JWT_EXPIRY_HOURS=48
ANOMALY_THRESHOLD=2.0            # default, configurable per event
SIMULATE_EMAIL=true              # set false when SendGrid is wired up
FRONTEND_URL=http://localhost:5173

RESEND_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_EMBEDDING_MODEL=nomic-embed-text-v1_5
ENVIRONMENT=development
